# Copy to .env and adjust for your environment (never commit .env).

# ---------------------------------------------------------------------------
# Application defaults (local / pilot / demonstration)
# ---------------------------------------------------------------------------
# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
UPDATE_GUARDIAN_LOG_LEVEL=INFO

# SQLite database URL (parent directories are created on first run). Paths are
# relative to the process working directory unless absolute. For Streamlit Cloud,
# prefer a persistent external database if you require durability across redeploys.
UPDATE_GUARDIAN_DATABASE_URL=sqlite:///./data/update_guardian.db

# Optional: shown in audit banners and exports (omit or leave empty for none).
# Example for an internal pilot (non-production label recommended in UI copy):
# UPDATE_GUARDIAN_ORGANIZATION_NAME=Sponsor QA — Software Update Triage Pilot

UPDATE_GUARDIAN_ORGANIZATION_NAME=

# ---------------------------------------------------------------------------
# Deployment and GxP-adjacent environments — read before production
# ---------------------------------------------------------------------------
# Secrets: Use Streamlit Secrets, a vault, or CI/CD variables instead of baking
# real credentials into images, forks, or long-lived branches.
# Scale-out: Multiple Streamlit replicas writing to one SQLite file on shared
# disk is unsafe; use a validated managed database and point
# UPDATE_GUARDIAN_DATABASE_URL at its SQLAlchemy URL (including TLS params).
# Logging: Use WARNING or ERROR in steady-state production; aggregate centrally
# and define retention per your records / IT policy (not enforced here).
# Validation: IQ/OQ/PQ, access control, backup/restore drills, and SOP mapping
# are organizational obligations—this template does not constitute a validation package.
