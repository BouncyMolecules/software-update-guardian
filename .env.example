# Copy to `.env` in the repo root and adjust per environment — never commit `.env`.

# =============================================================================
# Local / pilot defaults (mirror `Settings` in `src/update_guardian/config.py`)
# =============================================================================

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
UPDATE_GUARDIAN_LOG_LEVEL=INFO

# SQLite (default): path is relative to the process working directory unless absolute.
# First run creates parent directories (`data/` for this path pattern).
UPDATE_GUARDIAN_DATABASE_URL=sqlite:///./data/update_guardian.db

# PostgreSQL-style example — use managed credentials (vault / Streamlit Secrets / CI vars only):
# UPDATE_GUARDIAN_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@db.example.company:5432/update_guardian?sslmode=require

# Optional banner text in dashboard / exports (omit or leave empty).
# Synthetic example only — substitute your pilot label internally:
# UPDATE_GUARDIAN_ORGANIZATION_NAME=Clinical Systems — SW update triage (non-validated sandbox)

UPDATE_GUARDIAN_ORGANIZATION_NAME=

# =============================================================================
# Before production-grade use
# =============================================================================
#
# Secrets: Prefer Streamlit Cloud Secrets, a vault, or CI/CD variables —
# avoid long-lived passwords in repos, forks, or saved shell history.
#
# Concurrency: Multiple Streamlit replicas writing one SQLite file on shared
# storage is unsafe — use PostgreSQL/MySQL-compatible URLs with pooling per
# your IT standard.
#
# Logging: Prefer WARNING | ERROR plus centralized aggregation — retention per
# your records / IT policy (not enforced in code).
#
# Validation: IQ/OQ/PQ, access control, backup/restore rehearsal, DSAR/PI
# workflows, and SOP linkage are organizational obligations; this template is
# not a validation package or risk file.
